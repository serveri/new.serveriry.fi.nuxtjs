{
   "private": true,
   "scripts": {
      "build": "set NODE_OPTIONS=--no-deprecation && nuxt build",
      "dev": "nuxt dev",
      "start": "nuxt start",
      "generate": "nuxt generate",
      "preview": "nuxt preview",
      "prepare": "cd ../ && husky app/.husky",
      "postinstall": "nuxt prepare",
      "lint:script": "eslint --ext .ts,vue --ignore-path .gitignore .",
      "lint:style": "stylelint src/**/*.{css,scss,vue}",
      "lint:reset": "eslint",
      "format": "prettier --write src/**/*.{tsx,jsx,ts,js,vue}",
      "deps:check": "npx npm-check-updates",
      "deps:update": "npx npm-check-updates -u && npm install",
      "test:e2e": "playwright test --grep-invert @cms",
      "test:e2e:ui": "playwright test --ui --grep-invert @cms",
      "test:e2e:cms": "playwright test tests/cms-live.spec.ts --workers=1"
   },
   "dependencies": {
      "@fortawesome/fontawesome-svg-core": "^7.2.0",
      "@fortawesome/free-brands-svg-icons": "^7.2.0",
      "@fortawesome/free-regular-svg-icons": "^7.2.0",
      "@fortawesome/free-solid-svg-icons": "^7.2.0",
      "@fortawesome/vue-fontawesome": "^3.1.3",
      "@headlessui/vue": "^1.7.23",
      "@heroicons/vue": "^2.2.0",
      "@nuxtjs/i18n": "^10.2.3",
      "@playwright/test": "^1.58.2",
      "@vueuse/core": "^14.2.1",
      "globals": "^17.3.0",
      "nuxt": "^4.3.1",
      "tailwindcss": "^4.2.0",
      "vue": "^3.5.28",
      "vue-markdown-render": "^2.3.0",
      "vue-router": "^4.6.4"
   },
   "devDependencies": {
      "@eslint/eslintrc": "^3.3.3",
      "@eslint/js": "^9.39.2",
      "@nuxt/types": "^2.18.1",
      "@tailwindcss/postcss": "^4.2.0",
      "@types/node": "^25.3.0",
      "@typescript-eslint/eslint-plugin": "^8.56.0",
      "@typescript-eslint/parser": "^8.56.0",
      "autoprefixer": "^10.4.24",
      "eslint": "^9.39.2",
      "eslint-plugin-jsx-a11y": "^6.10.2",
      "eslint-plugin-prettier": "^5.5.5",
      "eslint-plugin-security": "^4.0.0",
      "eslint-plugin-vue": "^10.8.0",
      "husky": "^9.1.7",
      "lint-staged": "^16.2.7",
      "npm-check-updates": "^19.4.1",
      "playwright": "^1.58.2",
      "postcss": "^8.5.6",
      "postcss-html": "^1.8.1",
      "prettier": "^3.8.1",
      "stylelint": "^17.3.0",
      "stylelint-config-recommended": "^18.0.0",
      "stylelint-config-standard": "^40.0.0"
   },
   "optionalDependencies": {
      "@oxc-parser/binding-linux-x64-gnu": "0.114.0"
   },
   "lint-staged": {
      "*.{ts,tsx,js,jsx}": "eslint --fix",
      "*.{css,scss}": "stylelint --fix",
      "*.vue": [
         "eslint --fix",
         "stylelint --fix"
      ],
      "*.{json,md,html}": "prettier --write"
   }
}
